@model DateTime
@using System.Globalization
@{
    var utc = Model.Kind switch
    {
        DateTimeKind.Utc => Model,
        DateTimeKind.Local => Model.ToUniversalTime(),
        _ => DateTime.SpecifyKind(Model, DateTimeKind.Utc)
    };
    var isoUtc = utc.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", CultureInfo.InvariantCulture);
}
<time class="local-datetime" datetime="@isoUtc"></time>
