@model PlayerProfilePageViewModel
<div class="col-lg-8">
    <div class="secondLevelDiv profile-header-block h-100">
        <div class="profile-name-row">
            <h1 class="profile-name">@Model.PlayerName</h1>
            <button type="button"
                    class="featured-player-toggle"
                    data-steam-id="@Model.SteamId"
                    data-player-name="@Model.PlayerName"
                    aria-label="Save as featured player"
                    title="Save as featured player">
                <i class="bi bi-star" aria-hidden="true"></i>
            </button>
        </div>
        <div class="profile-rankings">
            <span>Overall rank: <strong>#@Model.OverallRank</strong></span>
            <span>Rank on @Model.CharacterDisplayName: <strong>#@Model.CharacterRank</strong></span>
            <span class="profile-rating">
                @Model.Rating
                <span class="profile-rating-deviation">± @Model.RatingDeviation</span>
            </span>
            <span class="profile-record">
                <span class="text-success">@Model.Wins W</span>
                <span class="profile-record-sep" aria-hidden="true">·</span>
                <span class="text-danger">@Model.Losses L</span>
                <span class="profile-record-sep" aria-hidden="true">·</span>
                <span class="@Model.WinrateCss">Wr @Model.WinratePercent.ToString("0.#")%</span>
            </span>
        </div>
    </div>
</div>
