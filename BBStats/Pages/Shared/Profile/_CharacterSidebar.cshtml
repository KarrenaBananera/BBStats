@model PlayerProfilePageViewModel
<div class="col-lg-4">
    <div class="secondLevelDiv profile-characters-panel h-100">
        @foreach (var character in Model.Characters)
        {
            <a asp-page="/Player/Index"
               asp-route-steamId="@Model.SteamId"
               asp-route-character="@character.Slug"
               class="profile-char-link @(character.IsActive ? "active" : null)">
                <span class="profile-char-name">
                    <img src="@CharacterImages.GetSmallIconUrl(character.DisplayName)"
                         alt=""
                         class="profile-char-icon"
                         loading="lazy" />
                    @character.DisplayName
                </span>
                <span class="profile-char-meta">
                    @character.Games games ·
                    <span class="profile-char-elo">@character.Rating <span class="profile-char-elo-deviation">± @character.RatingDeviation</span></span>
                </span>
            </a>
        }
    </div>
</div>
