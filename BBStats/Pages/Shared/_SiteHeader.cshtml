@using BBStats.Data
<header>
    <nav class="container d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
        <ul class="nav col-12 col-lg-auto me-lg-auto mb-3 justify-content-center mb-md-0">
            <li><a asp-page="/Top/Index">Top</a></li>
            <li class="nav-dropdown" data-nav-dropdown>
                <button type="button" class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                    Statistics
                </button>
                <div class="nav-dropdown-menu" role="menu">
                    @foreach (var character in CharactersSeed.All)
                    {
                        var slug = character.Name.ToLowerInvariant();
                        <a asp-page="/Statistics/Index"
                           asp-route-character="@slug"
                           class="nav-dropdown-item"
                           role="menuitem">@character.Name</a>
                    }
                </div>
            </li>
        </ul>
        <form class="col-12 col-sm-6 col-lg-auto mb-3 mb-lg-0" asp-page="/Search/Index" method="get" role="search">
            <input type="search"
                   name="q"
                   class="form-control form-control-dark text-bg-dark"
                   placeholder="Search player..."
                   aria-label="Search" />
        </form>
    </nav>
</header>