@page "/player/{steamId}/{character}/{matchPage?}"
@model BBStats.Pages.Player.IndexModel
@{
    ViewData["Title"] = $"{Model.Profile.PlayerName} — {Model.Profile.CharacterDisplayName}";
}

<div class="mainDiv container py-4">
    <div class="row profile-top g-3">
        <partial name="Profile/_ProfileHeader" model="Model.Profile" />
        <partial name="Profile/_CharacterSidebar" model="Model.Profile" />
    </div>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        if (Model.Profile.IsIgnored)
        {
            <form method="post" asp-page-handler="DeleteIgnoredPlayer" asp-route-id="@Model.Profile.SteamId" onsubmit="return confirm('Are you sure you want to unignore this player?');">
                <button type="submit" class="btn btn-success w-100">Unignore</button>
            </form>
        }
        else
        {
        <form method="post" asp-page-handler="IgnorePlayer" asp-route-id="@Model.Profile.SteamId" onsubmit="return confirm('Are you sure you want to ignore this player?');">
            <button type="submit" class="btn btn-danger w-100">Ignore</button>
        </form>
        }
    }

    @if (Model.Profile.Characters.Any(c => c.IsActive && c.Games > 0))
    {
        <div class="row mt-3">
            <div class="col-12">
                <div id="player-character-stats"
                     data-stats-url="@Url.Page("/Player/CharacterStats", new { steamId = Model.Profile.SteamId, character = Model.Profile.CharacterSlug })">
                </div>
            </div>
        </div>
    }

    <div class="row mt-3">
        <div class="col-12">
            <div class="secondLevelDiv">
                <h2 class="profile-matches-title">Matches</h2>

                @if (Model.Profile.HasMatches)
                {
                    <partial name="Profile/_MatchSeriesList" model="Model.Profile" />
                }
                else if (!string.IsNullOrEmpty(Model.Profile.EmptyMessage))
                {
                    <p class="text-white-50 mb-0">@Model.Profile.EmptyMessage</p>
                }

                @{
                    ViewData["PaginationClass"] = Model.Profile.HasMatches ? null : "mt-4";
                }
                <partial name="Profile/_ProfilePagination" model="Model.Profile" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/player-stats.js" asp-append-version="true"></script>
}
