@page "/"
@model BBStats.Pages.Top.IndexModel
@{
    ViewData["Title"] = "Top Players";
}

<div class="mainDiv container py-4">
    <section id="featured-players-section" class="featured-players-section mb-4" hidden>
        <div class="secondLevelDiv">
            <h2 class="featured-players-title">Featured Players</h2>
            <div id="featured-players-list" class="featured-players-list"></div>
        </div>
    </section>

    @{
        ViewData["GetPageUrl"] = new Func<int, string?>(Model.GetPageUrl);
    }
    <partial name="_TopPlayersTable" model="Model.Top" />
    <partial name="_TopPlayersPagination" model="Model.Top" />
</div>
