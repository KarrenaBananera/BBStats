@page
@model IgnoredPlayersModel
<h2>Manage Ignored Players</h2>
<div class="mainDiv container py-4">
    <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Player ID</th>
                    <th>Player Name</th>
                    <th>Reason</th>
                    <th>Created At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var player in Model.IgnoredPlayers)
                {
                    <tr>
                        <td>@player.PlayerId</td>
                        <td>@Model.PlayerNames.GetValueOrDefault(player.PlayerId, "Unknown")</td>
                        <td>@player.Reason</td>
                        <td>@player.CreatedAt</td>
                        <td>
                            <form method="post" asp-page-handler="DeleteIgnoredPlayer" asp-route-id="@player.PlayerId" onsubmit="return confirm('Are you sure you want to remove this player from the ignored list?');">
                                <input type="hidden" name="pageNumber" value="@Model.PageNumber" />
                                <button type="submit" class="btn btn-danger">Unignore</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>    
        @if (Model.TotalPages > 1)
        {
            <div class="pagination-container">

                <span class="tableButton">
                    @if (Model.PageNumber > 1)
                    {
                    <a class="tableButton"
                    aria-label="Previous page"
                    asp-page="/Admin/IgnoredPlayers"
                    asp-route-pageNumber="@(Model.PageNumber - 1)">
                    &lt;
                    </a>
                    } else {
                        <span class="tableButton disabled">&lt;</span>
                    }
                </span>
                

                <span class="tableButton disabled">
                    <span class="page-info mx-4">
                        @Model.PageNumber
                    </span>
                </span>

                
                <span class="tableButton">
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                    <a class="tableButton"
                    aria-label="Next page"
                    asp-page="/Admin/IgnoredPlayers"
                    asp-route-pageNumber="@(Model.PageNumber + 1)">
                    &gt;
                    </a>} 
                    else {
                        <span class="tableButton disabled">&gt;</span>
                    }
                </span>
                
            </div>
        }
    </div>
</div>